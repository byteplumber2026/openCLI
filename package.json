{
  "name": "open-cli",
  "version": "0.1.0",
  "description": "Multi-provider CLI AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "open-cli": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "openai": "^4.0.0",
    "chalk": "^5.3.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "fast-glob": "^3.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
